5. CREDIT CHECK + AI EXECUTION
// services/aiExecutor.js

import { generateAIResponse } from "./aiService.js";
import { buildFinancialPrompt } from "./promptBuilder.js";
import db from "../db/index.js";

export async function runAI(userId, projectId, userInput) {
  
  // 1. Check credit
  const credit = await db.query(
    `SELECT total_credits - used_credits AS remaining 
     FROM user_credits WHERE user_id = $1`,
    [userId]
  );

  if (credit.rows[0].remaining <= 0) {
    throw new Error("Insufficient credits");
  }

  // 2. Build prompt
  const prompt = buildFinancialPrompt(userInput);

  // 3. Save prompt
  const promptData = await db.query(
    `INSERT INTO prompts(user_id, project_id, input_prompt, ai_model, status)
     VALUES ($1,$2,$3,$4,'processing')
     RETURNING id`,
    [userId, projectId, userInput, process.env.AI_MODEL]
  );

  const promptId = promptData.rows[0].id;

  // 4. Call AI
  const aiResult = await generateAIResponse(prompt);

  // 5. Save output
  await db.query(
    `INSERT INTO prompt_outputs(prompt_id, output_type, content)
     VALUES ($1,'json',$2)`,
    [promptId, aiResult]
  );

  // 6. Deduct credit
  await db.query(
    `UPDATE user_credits 
     SET used_credits = used_credits + 1
     WHERE user_id = $1`,
    [userId]
  );

  return {
    promptId,
    result: aiResult
  };
}
6. API ENDPOINT (USER PROMPT)
// routes/aiRoutes.js

import express from "express";
import { runAI } from "../services/aiExecutor.js";

const router = express.Router();

router.post("/prompt", async (req, res) => {
  try {
    const { userId, projectId, input } = req.body;

    const result = await runAI(userId, projectId, input);

    res.json({
      success: true,
      data: result
    });

  } catch (error) {
    res.status(400).json({
      success: false,
      message: error.message
    });
  }
});

export default router;

