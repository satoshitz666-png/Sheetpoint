3. CREDIT SYSTEM (CORE MONETIZATION)
CREATE TABLE user_credits (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_id UUID UNIQUE REFERENCES users(id) ON DELETE CASCADE,
  total_credits INT DEFAULT 30,
  used_credits INT DEFAULT 0,
  last_updated TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- View untuk hitung remaining credit
CREATE VIEW user_credit_balance AS
SELECT 
  user_id,
  total_credits,
  used_credits,
  (total_credits - used_credits) AS remaining_credits
FROM user_credits;

CREATE TABLE credit_transactions (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_id UUID REFERENCES users(id) ON DELETE CASCADE,
  type VARCHAR(20), -- usage / topup / bonus
  amount INT,
  description TEXT,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_credit_user ON credit_transactions(user_id);

