11. BUSINESS LOGIC (IMPORTANT)
 Auto Deduct Credit Function
CREATE OR REPLACE FUNCTION deduct_credit(p_user_id UUID, p_amount INT)
RETURNS VOID AS $$
BEGIN
  UPDATE user_credits
  SET used_credits = used_credits + p_amount,
      last_updated = CURRENT_TIMESTAMP
  WHERE user_id = p_user_id;

  INSERT INTO credit_transactions(user_id, type, amount, description)
  VALUES (p_user_id, 'usage', p_amount, 'AI prompt usage');
END;
$$ LANGUAGE plpgsql;

Check Credit Before Prompt
CREATE OR REPLACE FUNCTION check_credit(p_user_id UUID)
RETURNS BOOLEAN AS $$
DECLARE remaining INT;
BEGIN
  SELECT (total_credits - used_credits)
  INTO remaining
  FROM user_credits
  WHERE user_id = p_user_id;

  IF remaining > 0 THEN
    RETURN TRUE;
  ELSE
    RETURN FALSE;
  END IF;
END;
$$ LANGUAGE plpgsql;

