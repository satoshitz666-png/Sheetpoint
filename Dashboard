<script>
// Navigation
function navigate(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const target = document.getElementById('page-' + page);
  if (target) target.classList.add('active');
  const navMap = {home:'home',prompt:'prompt',result:'result',projects:'projects',templates:'templates',insights:'insights',settings:'settings',billing:'billing'};
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'"+page+"'")) n.classList.add('active');
  });
}

// AI Generate simulation
function startGenerate() {
  navigate('prompt');
  const inputView = document.getElementById('prompt-input-view');
  const processing = document.getElementById('ai-processing');
  inputView.style.display = 'none';
  processing.classList.add('show');
  const steps = [1,2,3,4,5];
  const delays = [600,1200,1900,2600,3200];
  steps.forEach((s, i) => {
    setTimeout(() => {
      const el = document.getElementById('step-' + s);
      if (i > 0) document.getElementById('step-' + steps[i-1]).classList.remove('active');
      if (i > 0) {
        const prev = document.getElementById('step-' + steps[i-1]);
        prev.classList.add('done');
        prev.innerHTML = prev.innerHTML.replace('<circle cx="12" cy="12" r="10"/>','<polyline points="20 6 9 17 4 12"/>');
        prev.style.opacity = '1';
      }
      el.classList.add('active');
      el.style.opacity = '1';
    }, delays[i]);
  });
  setTimeout(() => {
    processing.classList.remove('show');
    inputView.style.display = 'block';
    // Reset steps
    steps.forEach(s => {
      const el = document.getElementById('step-' + s);
      el.classList.remove('done','active');
      el.style.opacity = s === 1 ? '1' : '0.4';
    });
    navigate('result');
  }, 4200);
}

function setIntent(el, label) {
  document.querySelectorAll('.intent-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}

function usePrompt(el) {
  const text = el.querySelector ? el.innerText.replace('›','').trim() : '';
  const ta = document.getElementById('pe-prompt');
  if (ta) ta.value = text;
}

function switchTab(el) {
  document.querySelectorAll('.rtab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

function setScen(el) {
  document.querySelectorAll('.sc-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

function showRefineBox() {
  const box = document.getElementById('refine-box');
  box.style.display = box.style.display === 'none' ? 'block' : 'none';
}

function toggleExport() {
  const dd = document.getElementById('export-dd');
  dd.classList.toggle('show');
}

document.addEventListener('click', (e) => {
  if (!e.target.closest('.export-wrap')) {
    document.getElementById('export-dd').classList.remove('show');
  }
});
</script>
