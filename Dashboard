<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SheetPoint — Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #0A0C10;
  --bg2:      #0F1218;
  --bg3:      #13171F;
  --surface:  #181C27;
  --surface2: #1E2333;
  --surface3: #232940;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.13);
  --border3:  rgba(255,255,255,0.20);
  --text:     #EEF0F7;
  --text2:    #8B93AD;
  --text3:    #4A5068;
  --gold:     #D4A843;
  --gold2:    #EFC060;
  --gold-dim: rgba(212,168,67,0.12);
  --gold-d2:  rgba(212,168,67,0.06);
  --blue:     #4A90E2;
  --blue-dim: rgba(74,144,226,0.12);
  --green:    #34D399;
  --green-dim:rgba(52,211,153,0.12);
  --red:      #F87171;
  --red-dim:  rgba(248,113,113,0.12);
  --purple:   #A78BFA;
  --purple-dim:rgba(167,139,250,0.12);
  --r:        10px;
  --r-lg:     16px;
  --r-xl:     20px;
  --sidebar:  220px;
  --font-d:   'Syne', sans-serif;
  --font-b:   'DM Sans', sans-serif;
  --font-m:   'DM Mono', monospace;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:var(--font-b);font-size:14px;display:flex;flex-direction:column;}

/* ── TOP BAR ── */
.topbar{
  height:52px;display:flex;align-items:center;justify-content:space-between;
  padding:0 20px 0 0;
  background:var(--bg2);border-bottom:1px solid var(--border);
  flex-shrink:0;z-index:50;
}
.topbar-logo{
  width:var(--sidebar);display:flex;align-items:center;gap:9px;
  padding:0 20px;font-family:var(--font-d);font-weight:700;font-size:17px;
  border-right:1px solid var(--border);height:100%;
}
.topbar-logo .logo-hex{
  width:28px;height:28px;background:var(--gold-dim);border:1px solid rgba(212,168,67,0.35);
  border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;
}
.topbar-logo .sp{color:var(--gold);}
.topbar-center{flex:1;display:flex;align-items:center;padding:0 24px;gap:12px;}
.topbar-search{
  display:flex;align-items:center;gap:8px;
  background:var(--surface);border:1px solid var(--border);border-radius:8px;
  padding:7px 14px;flex:1;max-width:380px;cursor:text;
}
.topbar-search input{
  background:transparent;border:none;outline:none;color:var(--text2);
  font-family:var(--font-b);font-size:13px;flex:1;
}
.topbar-search input::placeholder{color:var(--text3);}
.topbar-search svg{width:14px;height:14px;color:var(--text3);flex-shrink:0;}
.topbar-right{display:flex;align-items:center;gap:8px;}
.credit-badge{
  display:flex;align-items:center;gap:6px;
  background:var(--gold-dim);border:1px solid rgba(212,168,67,0.25);
  border-radius:8px;padding:5px 12px;cursor:pointer;
  transition:all .2s;
}
.credit-badge:hover{border-color:var(--gold);}
.credit-badge .cr-num{font-family:var(--font-d);font-size:14px;font-weight:700;color:var(--gold);}
.credit-badge .cr-label{font-size:11px;color:var(--text3);}
.credit-bar{width:60px;height:4px;background:var(--surface3);border-radius:10px;overflow:hidden;}
.credit-fill{height:100%;background:var(--gold);border-radius:10px;width:80%;}
.icon-btn{
  width:34px;height:34px;border-radius:8px;border:1px solid var(--border);
  background:transparent;color:var(--text2);cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:all .2s;
}
.icon-btn:hover{background:var(--surface);border-color:var(--border2);color:var(--text);}
.icon-btn svg{width:16px;height:16px;}
.avatar{
  width:32px;height:32px;border-radius:50%;
  background:var(--gold-dim);border:1px solid rgba(212,168,67,0.3);
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:600;color:var(--gold);cursor:pointer;
  font-family:var(--font-d);
}

/* ── LAYOUT ── */
.app-body{display:flex;flex:1;overflow:hidden;}

/* ── SIDEBAR ── */
.sidebar{
  width:var(--sidebar);background:var(--bg2);border-right:1px solid var(--border);
  display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;
}
.sidebar::-webkit-scrollbar{width:4px;}
.sidebar::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:4px;}
.nav-section{padding:8px 10px 4px;}
.nav-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;padding:8px 8px 4px;}
.nav-item{
  display:flex;align-items:center;gap:10px;padding:8px 10px;
  border-radius:8px;cursor:pointer;transition:all .15s;
  color:var(--text2);font-size:13px;position:relative;
  margin-bottom:1px;
}
.nav-item:hover{background:var(--surface);color:var(--text);}
.nav-item.active{background:var(--gold-dim);color:var(--gold);}
.nav-item.active::before{
  content:'';position:absolute;left:-10px;top:50%;transform:translateY(-50%);
  width:3px;height:60%;background:var(--gold);border-radius:0 3px 3px 0;
}
.nav-item svg{width:16px;height:16px;flex-shrink:0;}
.nav-item .badge{
  margin-left:auto;font-size:10px;font-family:var(--font-m);
  padding:2px 7px;border-radius:10px;
  background:var(--surface3);color:var(--text3);
}
.nav-item.active .badge{background:rgba(212,168,67,0.2);color:var(--gold);}
.sidebar-bottom{
  margin-top:auto;padding:12px 10px;border-top:1px solid var(--border);
}
.upgrade-card{
  background:var(--gold-d2);border:1px solid rgba(212,168,67,0.2);
  border-radius:var(--r);padding:14px;
}
.upgrade-card h4{font-family:var(--font-d);font-size:13px;font-weight:700;margin-bottom:4px;}
.upgrade-card p{font-size:11px;color:var(--text2);margin-bottom:10px;line-height:1.5;}
.btn-upgrade{
  width:100%;padding:7px;border-radius:7px;
  background:var(--gold);border:none;
  color:#0A0C10;font-family:var(--font-b);font-size:12px;font-weight:600;
  cursor:pointer;transition:all .2s;
}
.btn-upgrade:hover{background:var(--gold2);}

/* ── MAIN CONTENT ── */
.main{flex:1;overflow-y:auto;background:var(--bg);}
.main::-webkit-scrollbar{width:6px;}
.main::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:4px;}
.page{display:none;padding:28px 32px;}
.page.active{display:block;}

/* ── PAGE HEADER ── */
.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;}
.page-title{font-family:var(--font-d);font-size:22px;font-weight:700;}
.page-sub{font-size:13px;color:var(--text2);margin-top:4px;}
.header-actions{display:flex;gap:10px;align-items:center;}
.btn{
  display:inline-flex;align-items:center;gap:7px;
  padding:8px 16px;border-radius:8px;font-family:var(--font-b);
  font-size:13px;cursor:pointer;transition:all .2s;border:none;
}
.btn-gold{background:var(--gold);color:#0A0C10;font-weight:600;}
.btn-gold:hover{background:var(--gold2);transform:translateY(-1px);}
.btn-outline{background:transparent;border:1px solid var(--border2);color:var(--text2);}
.btn-outline:hover{border-color:var(--border3);color:var(--text);}
.btn-surface{background:var(--surface);border:1px solid var(--border);color:var(--text2);}
.btn-surface:hover{border-color:var(--border2);color:var(--text);}
.btn svg{width:14px;height:14px;}

/* ── STAT CARDS ── */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px;}
.stat-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);
  padding:18px 20px;position:relative;overflow:hidden;
}
.stat-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--accent,transparent);
}
.stat-card[data-a="gold"]{--accent:var(--gold);}
.stat-card[data-a="blue"]{--accent:var(--blue);}
.stat-card[data-a="green"]{--accent:var(--green);}
.stat-card[data-a="purple"]{--accent:var(--purple);}
.stat-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;}
.stat-val{font-family:var(--font-d);font-size:26px;font-weight:700;line-height:1;}
.stat-change{display:flex;align-items:center;gap:4px;margin-top:6px;font-size:11px;}
.stat-change.up{color:var(--green);}
.stat-change.down{color:var(--red);}
.stat-change.warn{color:var(--gold);}
.stat-icon{
  position:absolute;right:16px;top:16px;
  width:36px;height:36px;border-radius:9px;
  display:flex;align-items:center;justify-content:center;font-size:18px;
}

/* ── GRID LAYOUTS ── */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.grid-3-1{display:grid;grid-template-columns:2fr 1fr;gap:16px;}
.mt{margin-top:20px;}
.mb{margin-bottom:16px;}

/* ── CARD ── */
.card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--r-lg);padding:20px;
}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.card-title{font-family:var(--font-d);font-size:14px;font-weight:600;}
.card-action{font-size:12px;color:var(--gold);cursor:pointer;text-decoration:none;}
.card-action:hover{text-decoration:underline;}

/* ── QUICK PROMPT ── */
.quick-prompt{
  background:var(--surface2);border:1px solid var(--border2);border-radius:var(--r-xl);
  padding:20px;margin-bottom:24px;
}
.qp-label{font-size:11px;color:var(--text3);font-family:var(--font-m);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;}
.qp-input-wrap{display:flex;gap:10px;align-items:flex-end;}
.qp-input{
  flex:1;background:var(--bg3);border:1px solid var(--border2);border-radius:12px;
  padding:14px 16px;color:var(--text);font-family:var(--font-b);font-size:14px;
  outline:none;resize:none;height:52px;transition:border-color .2s;
  font-weight:300;
}
.qp-input::placeholder{color:var(--text3);}
.qp-input:focus{border-color:rgba(212,168,67,0.4);}
.qp-params{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
.qp-param{
  display:flex;align-items:center;gap:6px;
  background:var(--bg3);border:1px solid var(--border);border-radius:7px;
  padding:5px 10px;font-size:12px;color:var(--text2);cursor:pointer;
  transition:all .15s;
}
.qp-param:hover{border-color:var(--border2);color:var(--text);}
.qp-param select{
  background:transparent;border:none;color:var(--text2);font-family:var(--font-b);
  font-size:12px;outline:none;cursor:pointer;
}
.qp-send{
  width:52px;height:52px;border-radius:12px;border:none;
  background:var(--gold);cursor:pointer;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all .2s;
}
.qp-send:hover{background:var(--gold2);transform:translateY(-1px);}
.qp-send svg{width:20px;height:20px;}

/* ── RECENT PROJECTS ── */
.project-list{display:flex;flex-direction:column;gap:8px;}
.project-item{
  display:flex;align-items:center;gap:12px;padding:12px 14px;
  background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);
  cursor:pointer;transition:all .15s;
}
.project-item:hover{border-color:var(--border2);background:var(--surface);}
.project-icon{
  width:36px;height:36px;border-radius:9px;
  display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;
}
.project-info{flex:1;min-width:0;}
.project-name{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.project-meta{font-size:11px;color:var(--text3);margin-top:2px;}
.project-badge{
  font-size:10px;font-family:var(--font-m);padding:3px 8px;border-radius:6px;
  flex-shrink:0;
}

/* ── ACTIVITY ── */
.activity-list{display:flex;flex-direction:column;gap:0;}
.activity-item{
  display:flex;gap:12px;align-items:flex-start;
  padding:10px 0;border-bottom:1px solid var(--border);
}
.activity-item:last-child{border-bottom:none;}
.activity-dot{
  width:8px;height:8px;border-radius:50%;margin-top:5px;flex-shrink:0;
}
.activity-text{font-size:13px;color:var(--text2);line-height:1.5;}
.activity-time{font-size:11px;color:var(--text3);margin-top:2px;}

/* ── PROMPT ENGINE PAGE ── */
.prompt-engine{max-width:860px;margin:0 auto;}
.pe-hero{text-align:center;margin-bottom:32px;}
.pe-hero h2{font-family:var(--font-d);font-size:28px;font-weight:800;margin-bottom:8px;}
.pe-hero p{font-size:15px;color:var(--text2);}
.pe-box{
  background:var(--surface);border:1px solid var(--border2);border-radius:var(--r-xl);
  padding:24px;margin-bottom:20px;
}
.pe-textarea{
  width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);
  padding:16px;color:var(--text);font-family:var(--font-b);font-size:15px;font-weight:300;
  outline:none;resize:none;height:100px;transition:border-color .2s;line-height:1.6;
}
.pe-textarea::placeholder{color:var(--text3);}
.pe-textarea:focus{border-color:rgba(212,168,67,0.4);}
.pe-options{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:16px;}
.pe-opt{
  background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);
  padding:10px 12px;
}
.pe-opt label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;display:block;margin-bottom:6px;}
.pe-opt select{
  width:100%;background:transparent;border:none;color:var(--text2);
  font-family:var(--font-b);font-size:12px;outline:none;cursor:pointer;
}
.pe-footer{display:flex;align-items:center;justify-content:space-between;margin-top:16px;}
.credit-cost{
  display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text2);
}
.credit-cost .cost{color:var(--gold);font-weight:600;font-family:var(--font-m);}
.pe-generate{
  display:flex;align-items:center;gap:10px;
  padding:12px 28px;border-radius:10px;
  background:var(--gold);border:none;
  color:#0A0C10;font-family:var(--font-b);font-size:14px;font-weight:700;
  cursor:pointer;transition:all .25s;
}
.pe-generate:hover{background:var(--gold2);transform:translateY(-1px);}
.pe-generate svg{width:16px;height:16px;}

/* AI Processing animation */
.ai-processing{
  display:none;text-align:center;padding:40px;
  background:var(--surface);border:1px solid var(--border2);border-radius:var(--r-xl);
}
.ai-processing.show{display:block;}
.ai-spinner{
  width:56px;height:56px;border-radius:50%;margin:0 auto 20px;
  border:2px solid var(--border);border-top-color:var(--gold);
  animation:spin .8s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg);}}
.ai-steps{display:flex;flex-direction:column;gap:8px;margin-top:20px;text-align:left;max-width:320px;margin-left:auto;margin-right:auto;}
.ai-step{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text2);}
.ai-step.done{color:var(--green);}
.ai-step.active{color:var(--gold);}
.ai-step svg{width:14px;height:14px;flex-shrink:0;}

/* Intent chips */
.intent-chips{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;}
.intent-chip{
  padding:7px 14px;border-radius:8px;font-size:13px;cursor:pointer;
  border:1px solid var(--border);background:var(--bg3);color:var(--text2);
  transition:all .15s;display:flex;align-items:center;gap:7px;
}
.intent-chip:hover{border-color:var(--border2);}
.intent-chip.active{background:var(--gold-dim);border-color:rgba(212,168,67,0.4);color:var(--gold);}
.suggest-prompts{display:flex;flex-direction:column;gap:6px;}
.suggest-item{
  padding:10px 14px;border-radius:var(--r);
  background:var(--bg3);border:1px solid var(--border);
  font-size:13px;color:var(--text2);cursor:pointer;transition:all .15s;
  display:flex;align-items:center;justify-content:space-between;
}
.suggest-item:hover{border-color:var(--gold);color:var(--text);}
.suggest-item svg{width:12px;height:12px;color:var(--text3);}

/* ── RESULT / EDITOR ── */
.result-page{display:none;}
.result-page.show{display:block;}
.result-toolbar{
  display:flex;align-items:center;gap:10px;
  padding:12px 16px;background:var(--surface);border:1px solid var(--border);
  border-radius:var(--r-lg) var(--r-lg) 0 0;flex-wrap:wrap;
}
.result-tabs{display:flex;gap:2px;background:var(--bg3);border-radius:7px;padding:3px;}
.rtab{
  padding:5px 14px;border-radius:5px;font-size:12px;cursor:pointer;
  color:var(--text2);transition:all .15s;
}
.rtab.active{background:var(--surface2);color:var(--text);}
.toolbar-sep{width:1px;height:20px;background:var(--border);margin:0 4px;}
.ai-refine-btn{
  display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:7px;
  background:var(--purple-dim);border:1px solid rgba(167,139,250,0.25);
  color:var(--purple);font-size:12px;cursor:pointer;transition:all .2s;
}
.ai-refine-btn:hover{border-color:var(--purple);}
.ai-refine-btn svg{width:13px;height:13px;}
.export-btn{
  margin-left:auto;display:flex;align-items:center;gap:6px;
  padding:7px 16px;border-radius:8px;background:var(--gold);border:none;
  color:#0A0C10;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font-b);
  transition:all .2s;
}
.export-btn:hover{background:var(--gold2);}

/* Spreadsheet */
.sheet-wrap{
  background:var(--bg3);border:1px solid var(--border);
  border-top:none;border-radius:0 0 var(--r-lg) var(--r-lg);
  overflow:auto;max-height:360px;
}
.sheet-wrap::-webkit-scrollbar{width:6px;height:6px;}
.sheet-wrap::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:4px;}
table.sheet{border-collapse:collapse;width:100%;min-width:700px;}
table.sheet th,table.sheet td{
  padding:6px 12px;border:1px solid rgba(255,255,255,0.05);
  font-family:var(--font-m);font-size:11px;white-space:nowrap;
}
table.sheet th{
  background:var(--surface);color:var(--text3);font-weight:400;
  position:sticky;top:0;z-index:1;text-align:center;
}
table.sheet td{color:var(--text2);}
table.sheet td:first-child{background:var(--surface);color:var(--text3);position:sticky;left:0;z-index:1;font-weight:400;}
table.sheet td.val{text-align:right;color:var(--text);}
table.sheet td.formula{text-align:right;color:var(--blue);}
table.sheet td.good{text-align:right;color:var(--green);}
table.sheet td.warn{text-align:right;color:var(--gold);}
table.sheet td.bad{text-align:right;color:var(--red);}
table.sheet tr.header td{background:var(--surface2);color:var(--gold);font-weight:500;font-size:10px;text-transform:uppercase;letter-spacing:.06em;}
table.sheet tr:hover td{background:rgba(255,255,255,0.02);}

/* Insight panel */
.result-layout{display:grid;grid-template-columns:1fr 280px;gap:16px;margin-top:16px;}
.insight-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px;display:flex;flex-direction:column;gap:12px;}
.ip-title{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;}
.insight-item{
  padding:11px;border-radius:var(--r);border-left:2px solid var(--accent,var(--border2));
  background:var(--bg3);
}
.insight-item[data-t="risk"]{--accent:var(--red);}
.insight-item[data-t="warn"]{--accent:var(--gold);}
.insight-item[data-t="good"]{--accent:var(--green);}
.insight-item[data-t="info"]{--accent:var(--blue);}
.insight-tag{
  display:inline-block;font-size:9px;font-family:var(--font-m);
  padding:2px 7px;border-radius:5px;margin-bottom:5px;
  text-transform:uppercase;letter-spacing:.06em;
}
.insight-item[data-t="risk"] .insight-tag{background:var(--red-dim);color:var(--red);}
