6. FRONTEND – DASHBOARD
{
  "dashboard_page": "
'use client'

import { useState } from 'react'

export default function Dashboard() {
  const [prompt, setPrompt] = useState('')
  const [result, setResult] = useState('')

  const handleGenerate = async () => {
    const res = await fetch('/api/generate', {
      method: 'POST',
      body: JSON.stringify({ userId: 'USER_ID', prompt })
    })

    const data = await res.json()
    setResult(data.result)
  }

  return (
    <div className='p-6'>
      <h1 className='text-2xl font-bold'>AI Dashboard</h1>

      <textarea
        className='w-full p-3 border mt-4'
        placeholder='Enter your financial prompt...'
        onChange={(e) => setPrompt(e.target.value)}
      />

      <button onClick={handleGenerate} className='mt-3 bg-blue-500 px-4 py-2'>
        Generate
      </button>

      <pre className='mt-6 bg-gray-900 text-white p-4'>
        {result}
      </pre>
    </div>
  )
}
"
}

