        // Render Spreadsheet
        function renderSpreadsheet(data) {
            const tbody = document.getElementById('spreadsheetBody');
            const thead = document.querySelector('#spreadsheetTable thead tr');

            // Update headers
            thead.innerHTML = '<th class="w-12 px-3 py-2 text-xs font-semibold text-dark-400 border-r border-dark-700/50 sticky left-0 bg-dark-800 z-10"></th>';
            if (data.length > 0) {
                const cols = data[0].length;
                const colLetters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
                for (let c = 0; c < Math.max(cols, 6); c++) {
                    const letter = colLetters[c % 26] + (c >= 26 ? Math.floor(c / 26) : '');
                    thead.innerHTML += `<th class="px-3 py-2 text-xs font-semibold text-dark-400 border-r border-dark-700/50 min-w-[140px]">${letter}</th>`;
                }
            }

            // Render rows
            tbody.innerHTML = '';
            data.forEach((row, ri) => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-dark-800/50 transition-colors';

                const rowNum = document.createElement('td');
                rowNum.className = 'px-3 py-1.5 text-xs text-dark-500 border-r border-dark-700/50 text-center sticky left-0 bg-dark-900/50 font-mono';
                rowNum.textContent = ri + 1;
                tr.appendChild(rowNum);

                row.forEach((cell, ci) => {
                    const td = document.createElement('td');
                    td.className = 'px-3 py-1.5 text-sm border-r border-dark-700/50 cursor-pointer hover:bg-dark-700/30 transition-colors text-dark-200';
                    td.textContent = cell;
                    td.dataset.row = ri;
                    td.dataset.col = ci;
                    td.onclick = () => selectCell(ri, ci, td);

                    // Header row styling
                    if (ri === 0) {
                        td.classList.add('font-semibold', 'text-dark-300');
                        td.style.background = 'rgba(30, 41, 59, 0.5)';
                    }
                    // Total row styling
                    if (typeof cell === 'string' && (cell.startsWith('Total') || cell.startsWith('Net') || cell.startsWith('EBITDA') || cell.startsWith('Cumulative'))) {
                        td.classList.add('font-semibold', 'text-brand-300');
                    }

                    tr.appendChild(td);
                });

                // Fill empty cells
                if (data.length > 0 && row.length < data[0].length) {
                    for (let c = row.length; c < data[0].length; c++) {
                        const td = document.createElement('td');
                        td.className = 'px-3 py-1.5 text-sm border-r border-dark-700/50 cursor-pointer hover:bg-dark-700/30 transition-colors';
                        td.textContent = '';
                        td.dataset.row = ri;
                        td.dataset.col = c;
                        td.onclick = () => selectCell(ri, c, td);
                        tr.appendChild(td);
                    }
                }

                tbody.appendChild(tr);
            });
        }

        function selectCell(row, col, element) {
            // Remove previous selection
            document.querySelectorAll('.cell-edit').forEach(el => el.classList.remove('cell-edit'));
            element.classList.add('cell-edit');
            state.activeCell = { row, col };
            const colLetters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
            const colLetter = colLetters[col % 26] + (col >= 26 ? Math.floor(col / 26) : '');
            document.getElementById('activeCell').textContent = `${colLetter}${row + 1}`;
            document.getElementById('cellFormula').value = state.spreadsheetData[row]?.[col] || '';
        }

        // Cell formula input handler
        document.addEventListener('DOMContentLoaded', () => {
            const formulaInput = document.getElementById('cellFormula');
            formulaInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    const { row, col } = state.activeCell;
                    if (!state.spreadsheetData[row]) state.spreadsheetData[row] = [];
                    state.spreadsheetData[row][col] = formulaInput.value;
                    renderSpreadsheet(state.spreadsheetData);
                    showToast('✅', 'Cell updated');
                }
            });
        });

        // Editor Actions
        function editorAction(action) {
            switch (action) {
                case 'addRow':
                    const lastRow = state.spreadsheetData[state.spreadsheetData.length - 1];
                    const newRow = lastRow ? new Array(lastRow.length).fill('') : ['', '', '', '', ''];
                    state.spreadsheetData.push(newRow);
                    renderSpreadsheet(state.spreadsheetData);
                    showToast('➕', 'Baris ditambahkan');
                    break;
                case 'addCol':
                    state.spreadsheetData.forEach(row => row.push(''));
                    renderSpreadsheet(state.spreadsheetData);
                    showToast('➕', 'Kolom ditambahkan');
                    break;
                case 'deleteRow':
                    if (state.spreadsheetData.length > 2) {
                        state.spreadsheetData.pop();
                        renderSpreadsheet(state.spreadsheetData);
                        showToast('➖', 'Baris dihapus');
                    }
                    break;
                case 'deleteCol':
                    state.spreadsheetData.forEach(row => row.pop());
                    renderSpreadsheet(state.spreadsheetData);
                    showToast('➖', 'Kolom dihapus');
                    break;
                case 'formula':
                    showToast('Σ', 'Formula mode aktif - gunakan cell formula bar');
                    document.getElementById('cellFormula').focus();
                    break;
                default:
                    showToast('📝', `Action: ${action}`);
            }
        }

        // History
        function addHistory(prompt) {
            const entry = {
                id: Date.now(),
                prompt: prompt.substring(0, 80) + (prompt.length > 80 ? '...' : ''),
                fullPrompt: prompt,
                timestamp: new Date().toLocaleString(),
                tokensUsed: 2
            };
            state.history.unshift(entry);
            renderHistory();
        }

        function renderHistory() {
            const list = document.getElementById('generationList');
            const histList = document.getElementById('historyList');
            document.getElementById('historyCount').textContent = state.history.length;

            const html = state.history.map(h => `
                <div class="glass-light rounded-xl p-4 hover:border-brand-500/30 transition-all cursor-pointer group" onclick="loadFromHistory(${h.id})">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <p class="text-sm font-medium text-dark-200 group-hover:text-white transition-colors">${h.prompt}</p>
                            <div class="flex items-center gap-3 mt-2">
                                <span class="text-xs text-dark-500">${h.timestamp}</span>
                                <span class="text-xs text-amber-400/60">-${h.tokensUsed} token</span>
                            </div>
                        </div>
                        <svg class="w-5 h-5 text-dark-600 group-hover:text-brand-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                </div>
            `).join('');

            if (list) list.innerHTML = html || '<p class="text-sm text-dark-500 text-center py-4">Belum ada generasi</p>';
            if (histList) {
                histList.innerHTML = state.history.length > 0 ? state.history.map(h => `
                    <div class="glass-light rounded-xl p-4 hover:border-brand-500/30 transition-all">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <p class="text-sm font-medium text-dark-200">${h.prompt}</p>
                                <p class="text-xs text-dark-500 mt-1">${h.timestamp}</p>
                            </div>
                            <div class="flex gap-2">
                                <button onclick="loadFromHistory(${h.id})" class="p-2 rounded-lg hover:bg-dark-700 text-dark-400 hover:text-white transition-colors" title="Load">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                </button>
                                <button onclick="deleteHistory(${h.id})" class="p-2 rounded-lg hover:bg-dark-700 text-dark-400 hover:text-red-400 transition-colors" title="Delete">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                `).join('') : `
                    <div class="text-center py-16">
                        <svg class="w-16 h-16 mx-auto text-dark-700 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <p class="text-dark-500">Belum ada riwayat generasi</p>
                    </div>
                `;
            }
        }

        function loadFromHistory(id) {
            const entry = state.history.find(h => h.id === id);
            if (entry) {
                const data = generateMockData(entry.fullPrompt);
                state.spreadsheetData = data;
                renderSpreadsheet(data);
                switchTab('editor');
                showToast('📋', 'Data dimuat dari history');
            }
        }

        function deleteHistory(id) {
            state.history = state.history.filter(h => h.id !== id);
            renderHistory();
            showToast('🗑️', 'History dihapus');
        }

        // AI Brain
