                addBrainMessage('ai', 'Analisis selesai! Saya menemukan bahwa **Project E** adalah pilihan terbaik dengan ROI 100% dan payback period tercepat (2.5 tahun). Ada beberapa area risiko yang perlu diperhatikan, terutama peningkatan operating expense. Saya juga memberikan 3 rekomendasi optimasi yang bisa meningkatkan profitabilitas hingga 17%.');
            }, 1500);
        }

        function askBrain() {
            const input = document.getElementById('brainInput');
            const question = input.value.trim();
            if (!question) return;

            if (!useTokens(1)) return;

            addBrainMessage('user', question);
            input.value = '';

            setTimeout(() => {
                const responses = [
                    'Berdasarkan data spreadsheet Anda, revenue menunjukkan tren positif dengan growth rata-rata 12% per quarter. Saya merekomendasikan untuk mempertahankan strategi saat ini sambil meningkatkan efisiensi operasional.',
                    'Analisis menunjukkan net margin Anda di kisaran 19-20%, yang baik untuk industri ini. Untuk meningkatkan margin ke 25%, fokus pada pengurangan COGS dan optimasi pricing strategy.',
                    'Dari data yang ada, break even point tercapai di 1.000 unit per bulan. Dengan volume saat ini, Anda sudah berada di zona profit. Pertimbangkan ekspasi ke 1.500 unit untuk memaksimalkan profit.',
                    'Cash flow Anda sehat dengan cumulative positive Rp 362M di H1 2026. Saya menyarankan alokasi 30% surplus untuk reinvestment dan 20% untuk emergency fund.',
                ];
                const resp = responses[Math.floor(Math.random() * responses.length)];
                addBrainMessage('ai', resp);
