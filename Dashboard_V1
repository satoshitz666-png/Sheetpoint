    <script>
        // State
        let state = {
            tokens: 30,
            maxTokens: 30,
            history: [],
            currentSpreadsheet: null,
            activeCell: { row: 0, col: 0 },
            spreadsheetData: [],
            currentTab: 'generate',
            sidebarOpen: true
        };

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            initSpreadsheet();
            updateTokenDisplay();
        });

        // Token Management
        function useTokens(count) {
            if (state.tokens < count) {
                document.getElementById('noTokensModal').classList.remove('hidden');
                return false;
            }
            state.tokens -= count;
            updateTokenDisplay();
            return true;
        }

        function updateTokenDisplay() {
            const pct = state.tokens / state.maxTokens;
            const circle = document.getElementById('tokenCircle');
            const circumference = 150.8;
            circle.style.strokeDashoffset = circumference * (1 - pct);
            document.getElementById('tokenCount').textContent = state.tokens;
            document.getElementById('tokenDisplay').textContent = state.tokens;

            if (state.tokens === 0) {
                document.getElementById('tokenDisplay').classList.add('text-red-400');
                document.getElementById('tokenDisplay').classList.remove('text-white');
            }
        }

        // Tab Switching
        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.getElementById(`tab-${tab}`).classList.remove('hidden');

            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('bg-brand-500/10', 'text-brand-400');
                btn.classList.add('text-dark-400');
            });
            const activeBtn = document.querySelector(`[data-tab="${tab}"]`);
            if (activeBtn) {
                activeBtn.classList.add('bg-brand-500/10', 'text-brand-400');
                activeBtn.classList.remove('text-dark-400');
            }

            const titles = { generate: 'Generate Spreadsheet', editor: 'Editor & Builder', brain: 'AI Brain', history: 'History', templates: 'Templates' };
            document.getElementById('pageTitle').textContent = titles[tab] || '';
            state.currentTab = tab;
        }

        // Sidebar Toggle
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('-translate-x-full');
            state.sidebarOpen = !state.sidebarOpen;
        }

        // Quick Prompt
        function useQuickPrompt(prompt) {
            document.getElementById('promptInput').value = prompt;
            document.getElementById('promptInput').focus();
        }

        // Template
        function useTemplate(type) {
            if (!useTokens(1)) return;

            const templates = {
                'profit-loss': 'Buat laporan laba rugi dengan revenue, COGS, gross profit, operating expenses, dan net income',
                'balance-sheet': 'Buat neraca keuangan dengan assets, liabilities, dan equity',
                'cash-flow': 'Buat cash flow projection 12 bulan dengan operating, investing, financing activities',
                'budget': 'Buat annual budget planning dengan department allocation dan variance analysis',
                'investment': 'Buat investment analysis dengan ROI, NPV, IRR untuk multiple projects',
                'break-even': 'Buat break even analysis dengan fixed costs, variable costs, dan contribution margin'
            };

            showToast('📋', 'Template dimuat...');
            generateWithPrompt(templates[type]);
        }

        // Generate Spreadsheet
        function generateSpreadsheet() {
            const prompt = document.getElementById('promptInput').value.trim();
            if (!prompt) {
                showToast('⚠️', 'Masukkan prompt terlebih dahulu');
                return;
            }
            if (!useTokens(2)) return;
            generateWithPrompt(prompt);
        }

        function generateWithPrompt(prompt) {
            document.getElementById('promptInput').value = '';
            showLoadingState();

            setTimeout(() => {
                const data = generateMockData(prompt);
                state.currentSpreadsheet = { prompt, data, timestamp: new Date().toLocaleString() };
                state.spreadsheetData = data;

                renderSpreadsheet(data);
                addHistory(prompt);
                hideLoadingState();
                switchTab('editor');
                showToast('✅', 'Spreadsheet berhasil di-generate!');
            }, 2000);
        }

