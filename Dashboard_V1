<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FinAI Spreadsheet Builder & Decision Engine</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.0/300;400;500;600;700;800/index.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { inter: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: {
                            50: '#f0f5ff', 100: '#e0eaff', 200: '#c2d5ff', 300: '#93b4fd',
                            400: '#608efb', 500: '#3b6df7', 600: '#2550eb', 700: '#1d3fd8',
                            800: '#1e35ae', 900: '#1e308b', 950: '#142054'
                        },
                        dark: {
                            50: '#f8fafc', 100: '#f1f5f9', 200: '#e2e8f0', 300: '#cbd5e1',
                            400: '#94a3b8', 500: '#64748b', 600: '#475569', 700: '#334155',
                            800: '#1e293b', 900: '#0f172a', 950: '#020617'
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'float': 'float 3s ease-in-out infinite',
                        'glow': 'glow 2s ease-in-out infinite alternate',
                        'slide-up': 'slideUp 0.3s ease-out',
                        'fade-in': 'fadeIn 0.4s ease-out',
                        'typing': 'typing 1.5s infinite',
                    },
                    keyframes: {
                        float: { '0%, 100%': { transform: 'translateY(0px)' }, '50%': { transform: 'translateY(-10px)' } },
                        glow: { '0%': { boxShadow: '0 0 5px rgba(59, 109, 247, 0.3)' }, '100%': { boxShadow: '0 0 20px rgba(59, 109, 247, 0.6)' } },
                        slideUp: { '0%': { transform: 'translateY(20px)', opacity: '0' }, '100%': { transform: 'translateY(0)', opacity: '1' } },
                        fadeIn: { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
                        typing: { '0%': { content: '""' }, '33%': { content: '"."' }, '66%': { content: '".."' }, '100%': { content: '"..."' } },
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .scrollbar-thin::-webkit-scrollbar { width: 6px; }
        .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
        .scrollbar-thin::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
        .scrollbar-thin::-webkit-scrollbar-thumb:hover { background: #475569; }
        .glass { background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(148, 163, 184, 0.1); }
        .glass-light { background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(8px); border: 1px solid rgba(148, 163, 184, 0.08); }
        .gradient-border { border: 1px solid transparent; background-clip: padding-box; position: relative; }
        .gradient-border::before { content: ''; position: absolute; inset: -1px; border-radius: inherit; background: linear-gradient(135deg, #3b6df7, #8b5cf6, #3b6df7); z-index: -1; opacity: 0.5; }
        .token-ring { animation: rotate 8s linear infinite; }
        @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .cell-edit { outline: 2px solid #3b6df7; background: rgba(59, 109, 247, 0.1) !important; }
        .brain-glow { box-shadow: 0 0 30px rgba(139, 92, 246, 0.4), 0 0 60px rgba(139, 92, 246, 0.1); }
        .shimmer { background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.05) 50%, transparent 100%); background-size: 200% 100%; animation: shimmer 2s infinite; }
        @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
        .plan-card:hover { transform: translateY(-4px); transition: all 0.3s ease; }
        .sparkline { stroke-dasharray: 1000; stroke-dashoffset: 1000; animation: drawLine 2s ease forwards; }
        @keyframes drawLine { to { stroke-dashoffset: 0; } }
    </style>
</head>
<body class="bg-dark-950 text-white font-inter overflow-hidden">
    <div id="app" class="flex h-screen">
        <!-- Sidebar -->
        <aside id="sidebar" class="w-72 bg-dark-900 border-r border-dark-700/50 flex flex-col transition-all duration-300 z-30">
            <!-- Logo -->
            <div class="p-5 border-b border-dark-700/50">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-purple-500 flex items-center justify-center shadow-lg shadow-brand-500/30">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <h1 class="text-lg font-bold bg-gradient-to-r from-brand-400 to-purple-400 bg-clip-text text-transparent">FinAI Platform</h1>
                        <p class="text-[10px] text-dark-400 uppercase tracking-wider">Spreadsheet & Decision Engine</p>
                    </div>
                </div>
            </div>

            <!-- Token Display -->
            <div class="p-5 border-b border-dark-700/50">
                <div class="glass-light rounded-2xl p-4">
                    <div class="flex items-center justify-between mb-3">
                        <span class="text-xs font-semibold text-dark-300 uppercase tracking-wider">Credit Token</span>
                        <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 font-semibold">Trial</span>
                    </div>
                    <div class="flex items-center gap-3 mb-3">
                        <div class="relative w-14 h-14">
                            <svg class="w-14 h-14 -rotate-90" viewBox="0 0 56 56">
                                <circle cx="28" cy="28" r="24" fill="none" stroke="#1e293b" stroke-width="4"/>
                                <circle id="tokenCircle" cx="28" cy="28" r="24" fill="none" stroke="url(#tokenGrad)" stroke-width="4" stroke-linecap="round" stroke-dasharray="150.8" stroke-dashoffset="0"/>
                                <defs><linearGradient id="tokenGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#3b6df7"/><stop offset="100%" stop-color="#8b5cf6"/></linearGradient></defs>
                            </svg>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <span id="tokenCount" class="text-sm font-bold text-white">30</span>
                            </div>
                        </div>
                        <div class="flex-1">
                            <p class="text-2xl font-bold text-white" id="tokenDisplay">30</p>
                            <p class="text-xs text-dark-400">dari 30 token tersedia</p>
                        </div>
                    </div>
                    <button onclick="showUpgradeModal()" class="w-full py-2 px-3 rounded-xl bg-gradient-to-r from-brand-600 to-purple-600 text-xs font-semibold hover:from-brand-500 hover:to-purple-500 transition-all shadow-lg shadow-brand-500/20 hover:shadow-brand-500/40">
                        ⚡ Upgrade Plan
                    </button>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 p-4 space-y-1 overflow-y-auto scrollbar-thin">
                <p class="text-[10px] font-semibold text-dark-500 uppercase tracking-widest px-3 mb-2">Main Menu</p>
                <button onclick="switchTab('generate')" class="nav-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all bg-brand-500/10 text-brand-400" data-tab="generate">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    Generate Spreadsheet
                </button>
                <button onclick="switchTab('editor')" class="nav-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all text-dark-400 hover:bg-dark-800 hover:text-white" data-tab="editor">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Editor & Builder
                </button>
                <button onclick="switchTab('brain')" class="nav-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all text-dark-400 hover:bg-dark-800 hover:text-white" data-tab="brain">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                    AI Brain
                    <span class="ml-auto px-1.5 py-0.5 text-[10px] rounded-md bg-purple-500/20 text-purple-400 font-semibold">AI</span>
                </button>

                <p class="text-[10px] font-semibold text-dark-500 uppercase tracking-widest px-3 mb-2 mt-5">Workspace</p>
                <button onclick="switchTab('history')" class="nav-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all text-dark-400 hover:bg-dark-800 hover:text-white" data-tab="history">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    History
                    <span id="historyCount" class="ml-auto px-1.5 py-0.5 text-[10px] rounded-md bg-dark-700 text-dark-300">0</span>
                </button>
                <button onclick="switchTab('templates')" class="nav-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all text-dark-400 hover:bg-dark-800 hover:text-white" data-tab="templates">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
                    Templates
                </button>

                <p class="text-[10px] font-semibold text-dark-500 uppercase tracking-widest px-3 mb-2 mt-5">Export</p>
                <button onclick="showExportModal()" class="nav-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all text-dark-400 hover:bg-dark-800 hover:text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    Export Data
                </button>
            </nav>

            <!-- User Profile -->
            <div class="p-4 border-t border-dark-700/50">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500 to-purple-500 flex items-center justify-center text-sm font-bold">U</div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-white truncate">User Trial</p>
                        <p class="text-xs text-dark-400">trial@finai.com</p>
                    </div>
                    <button class="text-dark-500 hover:text-white transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </button>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <!-- Top Bar -->
            <header class="h-16 glass border-b border-dark-700/50 flex items-center justify-between px-6 z-20">
                <div class="flex items-center gap-4">
                    <button onclick="toggleSidebar()" class="lg:hidden text-dark-400 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                    </button>
                    <h2 id="pageTitle" class="text-lg font-semibold text-white">Generate Spreadsheet</h2>
                </div>
                <div class="flex items-center gap-3">
                    <div class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-lg bg-dark-800/50 border border-dark-700/50">
                        <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
                        <span class="text-xs text-dark-400">AI Engine Online</span>
                    </div>
                    <button onclick="showNotifications()" class="relative p-2 rounded-lg hover:bg-dark-800 transition-colors text-dark-400 hover:text-white">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                        <span class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-brand-500 rounded-full text-[10px] flex items-center justify-center font-bold">2</span>
                    </button>
                </div>
            </header>

            <!-- Content Area -->
            <div class="flex-1 overflow-y-auto scrollbar-thin p-6" id="contentArea">
                <!-- Generate Tab -->
                <div id="tab-generate" class="tab-content animate-fade-in">
                    <div class="max-w-4xl mx-auto">
                        <!-- Hero -->
                        <div class="text-center mb-8">
                            <h3 class="text-3xl font-bold mb-2">Buat Financial Spreadsheet</h3>
                            <p class="text-dark-400">Cukup deskripsikan kebutuhan Anda, AI akan membuatkan spreadsheet lengkap</p>
                        </div>

                        <!-- Quick Templates -->
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
                            <button onclick="useQuickPrompt('Buat laporan keuangan bulanan perusahaan dengan revenue, expense, dan net profit selama 12 bulan')" class="p-3 rounded-xl bg-dark-800/50 border border-dark-700/50 hover:border-brand-500/50 transition-all text-left group">
                                <div class="text-2xl mb-1">📊</div>
                                <p class="text-xs font-medium text-dark-300 group-hover:text-white">Laporan Keuangan</p>
                            </button>
                            <button onclick="useQuickPrompt('Buat analisis cash flow dengan proyeksi 6 bulan ke depan termasuk inflow dan outflow')" class="p-3 rounded-xl bg-dark-800/50 border border-dark-700/50 hover:border-brand-500/50 transition-all text-left group">
                                <div class="text-2xl mb-1">💰</div>
                                <p class="text-xs font-medium text-dark-300 group-hover:text-white">Cash Flow</p>
                            </button>
                            <button onclick="useQuickPrompt('Buat budget planning tahunan dengan kategori marketing, operational, dan salary allocation')" class="p-3 rounded-xl bg-dark-800/50 border border-dark-700/50 hover:border-brand-500/50 transition-all text-left group">
                                <div class="text-2xl mb-1">📋</div>
                                <p class="text-xs font-medium text-dark-300 group-hover:text-white">Budget Planning</p>
                            </button>
                            <button onclick="useQuickPrompt('Buat investment analysis spreadsheet dengan ROI, NPV, IRR calculation untuk 5 proyek')" class="p-3 rounded-xl bg-dark-800/50 border border-dark-700/50 hover:border-brand-500/50 transition-all text-left group">
                                <div class="text-2xl mb-1">📈</div>
                                <p class="text-xs font-medium text-dark-300 group-hover:text-white">Investment Analysis</p>
                            </button>
                        </div>

                        <!-- Prompt Input -->
                        <div class="glass-light rounded-2xl p-1 mb-6">
                            <div class="p-4">
                                <textarea id="promptInput" rows="4" class="w-full bg-transparent text-white placeholder-dark-500 resize-none focus:outline-none text-sm" placeholder="Contoh: Buatkan laporan laba rugi kuartal 3 tahun 2026 dengan detail revenue stream, COGS, operating expense, dan margin analysis..."></textarea>
                                <div class="flex items-center justify-between mt-3 pt-3 border-t border-dark-700/50">
                                    <div class="flex items-center gap-2">
                                        <button onclick="attachFile()" class="p-1.5 rounded-lg hover:bg-dark-700 transition-colors text-dark-400 hover:text-white" title="Attach file">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                                        </button>
                                        <button class="p-1.5 rounded-lg hover:bg-dark-700 transition-colors text-dark-400 hover:text-white" title="Voice input">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                                        </button>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span id="tokenCost" class="text-xs text-amber-400/80">~2 token</span>
                                        <button onclick="generateSpreadsheet()" id="generateBtn" class="px-5 py-2 rounded-xl bg-gradient-to-r from-brand-600 to-brand-500 text-sm font-semibold hover:from-brand-500 hover:to-brand-400 transition-all shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40 flex items-center gap-2">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                            Generate
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Recent Generations -->
                        <div id="recentGenerations" class="space-y-3">
                            <p class="text-xs font-semibold text-dark-500 uppercase tracking-wider mb-3">Generasi Terbaru</p>
                            <div id="generationList" class="space-y-2">
                                <!-- Dynamic content -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Editor Tab -->
                <div id="tab-editor" class="tab-content hidden">
                    <div class="h-full flex flex-col">
                        <!-- Toolbar -->
                        <div class="flex items-center gap-2 mb-4 pb-4 border-b border-dark-700/50">
                            <div class="flex items-center gap-1 bg-dark-800/50 rounded-lg p-1">
                                <button onclick="editorAction('bold')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white" title="Bold"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg></button>
                                <button onclick="editorAction('italic')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white" title="Italic"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 4h4m-8 16h4M14 4L10 20"/></svg></button>
                                <div class="w-px h-5 bg-dark-700 mx-1"></div>
                                <button onclick="editorAction('addRow')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white text-xs" title="Add Row">+ Row</button>
                                <button onclick="editorAction('addCol')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white text-xs" title="Add Column">+ Col</button>
                                <button onclick="editorAction('deleteRow')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white text-xs" title="Delete Row">- Row</button>
                                <button onclick="editorAction('deleteCol')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white text-xs" title="Delete Column">- Col</button>
                            </div>
                            <div class="w-px h-6 bg-dark-700"></div>
                            <div class="flex items-center gap-1 bg-dark-800/50 rounded-lg p-1">
                                <button onclick="editorAction('alignLeft')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h10M4 18h14"/></svg></button>
                                <button onclick="editorAction('alignCenter')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M7 12h10M5 18h14"/></svg></button>
                                <button onclick="editorAction('alignRight')" class="p-1.5 rounded hover:bg-dark-700 transition-colors text-dark-400 hover:text-white"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M10 12h10M6 18h14"/></svg></button>
