        }

        function addBrainMessage(type, text) {
            const chat = document.getElementById('brainChat');
            const div = document.createElement('div');
            div.className = 'flex gap-3 animate-slide-up';

            if (type === 'user') {
                div.innerHTML = `
                    <div class="flex-1"></div>
                    <div class="glass rounded-xl p-3 max-w-lg bg-brand-500/10 border-brand-500/20">
                        <p class="text-sm text-dark-200">${text}</p>
                    </div>
                    <div class="w-8 h-8 rounded-lg bg-dark-700 flex items-center justify-center flex-shrink-0">
                        <span class="text-sm">U</span>
                    </div>
                `;
            } else {
                div.innerHTML = `
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-brand-500 flex items-center justify-center flex-shrink-0">
