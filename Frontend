<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SheetPoint — Spreadsheet that thinks.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0A0C10;
    --bg2: #0F1218;
    --bg3: #151921;
    --surface: #1A1F2E;
    --surface2: #1F2535;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #F0F2F7;
    --text2: #8B92A8;
    --text3: #555C72;
    --gold: #D4A843;
    --gold2: #F0C060;
    --gold-dim: rgba(212,168,67,0.12);
    --gold-dim2: rgba(212,168,67,0.06);
    --blue: #3B82F6;
    --blue-dim: rgba(59,130,246,0.1);
    --green: #22C55E;
    --green-dim: rgba(34,197,94,0.1);
    --red: #EF4444;
    --radius: 12px;
    --radius-lg: 20px;
    --font-display: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 48px;
    background: rgba(10,12,16,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-weight: 700; font-size: 20px;
    display: flex; align-items: center; gap: 8px;
  }
  .nav-logo span { color: var(--gold); }
  .logo-icon {
    width: 28px; height: 28px;
    background: var(--gold-dim);
    border: 1px solid var(--gold);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
  }
  .nav-links { display: flex; align-items: center; gap: 32px; }
  .nav-links a {
    color: var(--text2); text-decoration: none;
    font-size: 14px; font-weight: 400;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    display: flex; align-items: center; gap: 12px;
  }
  .btn-ghost {
    padding: 8px 16px; border-radius: 8px;
    background: transparent; border: 1px solid var(--border2);
    color: var(--text2); font-family: var(--font-body);
    font-size: 14px; cursor: pointer; transition: all 0.2s;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }
  .btn-primary {
    padding: 8px 20px; border-radius: 8px;
    background: var(--gold); border: none;
    color: #0A0C10; font-family: var(--font-body);
    font-size: 14px; font-weight: 600; cursor: pointer;
    transition: all 0.2s;
  }
  .btn-primary:hover { background: var(--gold2); transform: translateY(-1px); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 120px 48px 80px;
    position: relative; overflow: hidden;
    text-align: center;
  }
  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 800px 500px at 50% 0%, rgba(212,168,67,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 600px 400px at 80% 60%, rgba(59,130,246,0.04) 0%, transparent 60%);
  }
  .hero-grid {
    position: absolute; inset: 0; z-index: 0; opacity: 0.15;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 80%);
  }
  .hero-badge {
    position: relative; z-index: 1;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 16px; border-radius: 100px;
    background: var(--gold-dim); border: 1px solid rgba(212,168,67,0.3);
    font-size: 13px; color: var(--gold); font-weight: 500;
    margin-bottom: 32px;
    animation: fadeUp 0.6s ease both;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero h1 {
    position: relative; z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 88px);
    font-weight: 800; line-height: 1.05;
    letter-spacing: -0.03em;
    animation: fadeUp 0.6s 0.1s ease both;
  }
  .hero h1 .accent { color: var(--gold); }
  .hero h1 .dim { color: var(--text2); }
  .hero-sub {
    position: relative; z-index: 1;
    font-size: 20px; color: var(--text2);
    font-weight: 300; max-width: 520px;
    margin: 24px auto 0;
    line-height: 1.6;
    animation: fadeUp 0.6s 0.2s ease both;
  }
  .hero-actions {
    position: relative; z-index: 1;
    display: flex; align-items: center; gap: 16px;
    margin-top: 40px;
    animation: fadeUp 0.6s 0.3s ease both;
  }
  .btn-hero {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 28px; border-radius: 10px;
    background: var(--gold); border: none;
    color: #0A0C10; font-family: var(--font-body);
    font-size: 15px; font-weight: 600; cursor: pointer;
    transition: all 0.25s;
  }
  .btn-hero:hover { background: var(--gold2); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(212,168,67,0.25); }
  .btn-hero-outline {
    display: flex; align-items: center; gap: 8px;
    padding: 14px 28px; border-radius: 10px;
    background: transparent; border: 1px solid var(--border2);
    color: var(--text2); font-family: var(--font-body);
    font-size: 15px; cursor: pointer; transition: all 0.25s;
  }
  .btn-hero-outline:hover { border-color: var(--text2); color: var(--text); }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* DASHBOARD PREVIEW */
  .dashboard-preview {
    position: relative; z-index: 1;
    margin-top: 64px;
    width: 100%; max-width: 1000px;
    animation: fadeUp 0.6s 0.4s ease both;
  }
  .preview-label {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; color: var(--text3); font-family: var(--font-mono);
    margin-bottom: 12px;
  }
  .preview-window {
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.5);
  }
  .preview-bar {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 16px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
  }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background: #FF5F57; }
  .dot-y { background: #FFBD2E; }
  .dot-g { background: #28CA41; }
  .preview-title { flex: 1; text-align: center; font-size: 12px; color: var(--text3); font-family: var(--font-mono); }
  .preview-body {
    display: grid;
    grid-template-columns: 200px 1fr 220px;
    min-height: 400px;
  }
  .sidebar {
    background: var(--bg3);
    border-right: 1px solid var(--border);
    padding: 16px 0;
  }
  .sidebar-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 16px;
    font-size: 13px; color: var(--text2); cursor: pointer;
    transition: all 0.15s;
  }
  .sidebar-item.active { background: var(--gold-dim2); color: var(--gold); border-right: 2px solid var(--gold); }
  .sidebar-item svg { width: 15px; height: 15px; opacity: 0.7; }
  .sidebar-item.active svg { opacity: 1; }
  .sidebar-label { font-size: 10px; color: var(--text3); padding: 12px 16px 6px; text-transform: uppercase; letter-spacing: 0.08em; }
  .main-area { padding: 16px; display: flex; flex-direction: column; gap: 12px; }
  .prompt-bar {
    display: flex; align-items: center; gap: 10px;
    background: var(--surface); border: 1px solid var(--border2);
    border-radius: 10px; padding: 10px 14px;
  }
  .prompt-input {
    flex: 1; font-family: var(--font-body); font-size: 13px;
    color: var(--text2);
  }
  .prompt-send {
    width: 28px; height: 28px; border-radius: 6px;
    background: var(--gold); display: flex; align-items: center; justify-content: center;
    cursor: pointer; flex-shrink: 0;
  }
  .prompt-send svg { width: 14px; height: 14px; }
  .spreadsheet-area {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
    font-family: var(--font-mono); font-size: 11px;
  }
  .sheet-header {
    display: grid;
    grid-template-columns: 80px repeat(5, 1fr);
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
  }
  .sheet-cell {
    padding: 5px 8px;
    border-right: 1px solid var(--border);
    color: var(--text3);
    font-size: 10px; text-align: center;
  }
  .sheet-row { display: grid; grid-template-columns: 80px repeat(5, 1fr); border-bottom: 1px solid var(--border); }
  .sheet-row:last-child { border-bottom: none; }
  .sheet-row .sheet-cell { color: var(--text2); text-align: right; }
  .sheet-row .sheet-cell:first-child { color: var(--text3); text-align: left; font-size: 10px; }
  .sheet-row .sheet-cell.formula { color: var(--blue); }
  .sheet-row .sheet-cell.good { color: var(--green); }
  .sheet-row .sheet-cell.warn { color: var(--gold); }
  .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .kpi-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 12px;
  }
  .kpi-label { font-size: 10px; color: var(--text3); margin-bottom: 4px; }
  .kpi-value { font-size: 18px; font-weight: 600; font-family: var(--font-display); color: var(--text); }
  .kpi-change { font-size: 10px; margin-top: 2px; }
  .kpi-change.up { color: var(--green); }
  .kpi-change.down { color: var(--red); }
  .right-panel {
    background: var(--bg3);
    border-left: 1px solid var(--border);
    padding: 14px; display: flex; flex-direction: column; gap: 12px;
    overflow: hidden;
  }
  .panel-title { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; }
  .insight-card {
    background: var(--surface); border-radius: 8px; padding: 10px;
    border-left: 2px solid var(--gold);
  }
  .insight-card.warn { border-left-color: var(--gold); }
  .insight-card.good { border-left-color: var(--green); }
  .insight-card.info { border-left-color: var(--blue); }
  .insight-text { font-size: 11px; color: var(--text2); line-height: 1.5; }
  .insight-tag { display: inline-block; font-size: 9px; font-family: var(--font-mono); padding: 2px 6px; border-radius: 4px; margin-bottom: 5px; }
  .insight-tag.risk { background: rgba(212,168,67,0.15); color: var(--gold); }
  .insight-tag.ok { background: rgba(34,197,94,0.15); color: var(--green); }
  .insight-tag.tip { background: rgba(59,130,246,0.15); color: var(--blue); }
  .scenario-toggle { display: flex; gap: 4px; }
  .scen-btn {
    flex: 1; padding: 5px 4px; font-size: 10px; border-radius: 5px;
    border: 1px solid var(--border); background: transparent;
    color: var(--text3); cursor: pointer; font-family: var(--font-body);
    transition: all 0.15s;
  }
  .scen-btn.active { background: var(--gold-dim); border-color: var(--gold); color: var(--gold); }
  .rec-item {
    background: var(--surface); border-radius: 6px; padding: 8px;
    font-size: 11px; color: var(--text2); line-height: 1.5;
    display: flex; align-items: flex-start; gap: 6px;
  }
  .rec-arrow { color: var(--gold); font-weight: 600; flex-shrink: 0; }

  /* SECTION WRAPPER */
  section { padding: 100px 48px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-label {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-family: var(--font-mono);
    color: var(--gold); margin-bottom: 16px;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700; line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .text-gold { color: var(--gold); }
  .subtitle { font-size: 18px; color: var(--text2); font-weight: 300; max-width: 500px; line-height: 1.6; }

  /* PROBLEM SECTION */
  .problem-section { background: var(--bg); }
  .problem-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
    margin-top: 56px;
  }
  .problem-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 28px 24px;
    position: relative; overflow: hidden;
    transition: border-color 0.3s;
  }
  .problem-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0; transition: opacity 0.3s;
  }
  .problem-card:hover { border-color: var(--border2); }
  .problem-card:hover::before { opacity: 1; }
  .problem-icon {
    width: 44px; height: 44px; border-radius: 10px;
    background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px; font-size: 20px;
  }
  .problem-card h3 { font-family: var(--font-display); font-size: 18px; font-weight: 600; margin-bottom: 8px; }
  .problem-card p { font-size: 14px; color: var(--text2); line-height: 1.6; }

  /* SOLUTION */
  .solution-section { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .flow-steps {
    display: grid; grid-template-columns: 1fr 40px 1fr 40px 1fr;
    align-items: center; gap: 0;
    margin-top: 56px;
  }
  .flow-step {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 32px 28px;
    text-align: center; position: relative;
  }
  .flow-step::after {
    content: '';
    position: absolute; inset: 0; border-radius: var(--radius-lg);
    background: radial-gradient(ellipse at 50% 0%, var(--gold-dim2), transparent 70%);
    pointer-events: none;
  }
  .flow-num {
    font-family: var(--font-mono); font-size: 11px; color: var(--gold);
    margin-bottom: 12px; display: block;
  }
  .flow-icon { font-size: 36px; margin-bottom: 16px; display: block; }
  .flow-step h3 { font-family: var(--font-display); font-size: 22px; font-weight: 700; margin-bottom: 8px; }
  .flow-step p { font-size: 14px; color: var(--text2); }
  .flow-arrow { text-align: center; color: var(--text3); }
  .flow-arrow svg { width: 24px; height: 24px; }

  /* FEATURES */
  .features-section { background: var(--bg); }
  .features-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;
    margin-top: 56px;
  }
  .feature-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 32px;
    transition: all 0.3s; cursor: default; position: relative; overflow: hidden;
  }
  .feature-card:hover { border-color: var(--border2); transform: translateY(-2px); }
  .feature-card.featured {
    background: var(--surface2);
    border-color: rgba(212,168,67,0.25);
    grid-column: span 2;
    display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;
  }
  .feature-tag {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-family: var(--font-mono);
    padding: 4px 10px; border-radius: 100px;
    background: var(--gold-dim); color: var(--gold);
    margin-bottom: 16px;
  }
  .feature-tag.blue { background: var(--blue-dim); color: var(--blue); }
  .feature-tag.green { background: var(--green-dim); color: var(--green); }
  .feature-card h3 { font-family: var(--font-display); font-size: 24px; font-weight: 700; margin-bottom: 10px; }
  .feature-card p { font-size: 15px; color: var(--text2); line-height: 1.65; }
  .feature-list { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
  .feature-list li {
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; color: var(--text2); list-style: none;
  }
  .feature-list li::before { content: '—'; color: var(--gold); font-weight: 600; flex-shrink: 0; }
  .mock-formula {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 10px; padding: 20px;
    font-family: var(--font-mono); font-size: 12px;
    line-height: 1.8;
  }
  .mock-formula .comment { color: var(--text3); }
  .mock-formula .fn { color: var(--blue); }
  .mock-formula .val { color: var(--gold); }
  .mock-formula .str { color: var(--green); }

  /* WEB3 */
  .web3-section { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .web3-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; margin-top: 56px; }
  .web3-features { display: flex; flex-direction: column; gap: 20px; }
  .web3-item { display: flex; gap: 16px; align-items: flex-start; }
  .web3-item-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--gold-dim); border: 1px solid rgba(212,168,67,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .web3-item h4 { font-family: var(--font-display); font-size: 16px; font-weight: 600; margin-bottom: 4px; }
  .web3-item p { font-size: 14px; color: var(--text2); line-height: 1.5; }
  .web3-visual {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px; overflow: hidden;
  }
  .token-chart {
    margin-bottom: 20px;
  }
  .chart-label { font-size: 11px; color: var(--text3); font-family: var(--font-mono); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .token-bar-row { margin-bottom: 8px; }
  .token-bar-label {
    display: flex; justify-content: space-between;
    font-size: 12px; color: var(--text2); margin-bottom: 4px;
  }
  .token-bar-track {
    height: 6px; background: var(--surface2); border-radius: 100px; overflow: hidden;
  }
  .token-bar-fill { height: 100%; border-radius: 100px; }
  .vesting-table { width: 100%; border-collapse: collapse; font-size: 11px; font-family: var(--font-mono); }
  .vesting-table th { color: var(--text3); text-align: left; padding: 4px 0; border-bottom: 1px solid var(--border); font-weight: 400; }
  .vesting-table td { padding: 5px 0; color: var(--text2); border-bottom: 1px solid var(--border); }
  .vesting-table td:last-child { text-align: right; color: var(--gold); }

  /* SOCIAL PROOF */
  .proof-section { background: var(--bg); }
  .metrics-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 56px; }
  .metric-card {
    text-align: center; padding: 32px 20px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .metric-num {
    font-family: var(--font-display); font-size: 48px;
    font-weight: 800; color: var(--gold); line-height: 1;
  }
  .metric-label { font-size: 14px; color: var(--text2); margin-top: 8px; }

  /* CTA */
  .cta-section {
    padding: 120px 48px;
    background: var(--bg2); border-top: 1px solid var(--border);
    text-align: center; position: relative; overflow: hidden;
  }
  .cta-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 700px 400px at 50% 50%, rgba(212,168,67,0.05), transparent 70%);
  }
  .cta-section h2 { position: relative; z-index: 1; }
  .cta-section p { position: relative; z-index: 1; font-size: 18px; color: var(--text2); margin: 16px 0 40px; }
  .cta-actions { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; gap: 16px; }
  .btn-cta {
    padding: 16px 36px; border-radius: 10px;
    background: var(--gold); border: none;
    color: #0A0C10; font-family: var(--font-body);
    font-size: 16px; font-weight: 600; cursor: pointer;
    transition: all 0.25s;
  }
  .btn-cta:hover { background: var(--gold2); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(212,168,67,0.3); }
  .btn-cta-outline {
    padding: 16px 36px; border-radius: 10px;
    background: transparent; border: 1px solid var(--border2);
    color: var(--text2); font-family: var(--font-body);
    font-size: 16px; cursor: pointer; transition: all 0.25s;
  }
