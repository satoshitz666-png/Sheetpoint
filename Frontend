  // Scenario toggle
  document.querySelectorAll('.scen-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.scen-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
