 4. NEXT.JS API IMPLEMENTATION (REAL CODE)
 /app/api/prompt/route.js
import { NextResponse } from "next/server";
import { runAI } from "@/lib/aiExecutor";

export async function POST(req) {
  try {
    const body = await req.json();
    const { userId, projectId, input } = body;

    const result = await runAI(userId, projectId, input);

    return NextResponse.json({
      success: true,
      data: result
    });

  } catch (err) {
    return NextResponse.json({
      success: false,
      message: err.message
    }, { status: 400 });
  }
}

5. AI SERVICE (NEXT.JS)
// lib/aiService.js

import OpenAI from "openai";

const client = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY
});

export async function generateAI(prompt) {
  const response = await client.chat.completions.create({
    model: "gpt-4.1-mini",
    messages: [
      {
        role: "system",
        content: "You are financial AI. Output JSON only."
      },
      {
        role: "user",
        content: prompt
      }
    ]
  });

  return response.choices[0].message.content;
}

